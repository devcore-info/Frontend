{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "src/main/webapp/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/src/main/webapp/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/src/main/webapp/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/main/webapp/$1"
    }
  ]
}
